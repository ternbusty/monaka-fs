// Halycon VFS Provider World Definition
// This component provides an in-memory VFS implementation compatible with WASI Preview 2

package halycon:vfs@0.1.0;

world vfs-provider {
    // Import wall clock for timestamps
    import wasi:clocks/wall-clock@0.2.0;

    // Export WASI filesystem interfaces
    export wasi:filesystem/types@0.2.0;
    export wasi:filesystem/preopens@0.2.0;
}
