// WASI filesystem types Host trait implementation for RPC client

use anyhow::anyhow;
use vfs_rpc_protocol::{ErrorCode, Request, Response};
use wasmtime::component::Resource;
use wasmtime_wasi::bindings::sync::filesystem::types::{
    Advice, DescriptorFlags, DescriptorStat, DescriptorType, DirectoryEntry,
    MetadataHashValue, NewTimestamp, OpenFlags, PathFlags,
};
use wasmtime_wasi::TrappableError;

use crate::VfsRpcHostState;

// Convert RPC ErrorCode to WASI non-sync ErrorCode for TrappableError
fn rpc_error_to_wasi(
    code: ErrorCode,
) -> TrappableError<wasmtime_wasi::bindings::filesystem::types::ErrorCode> {
    use wasmtime_wasi::bindings::filesystem::types::ErrorCode as NonSyncErrorCode;

    let error_code = match code {
        ErrorCode::NotFound => NonSyncErrorCode::NoEntry,
        ErrorCode::NotADirectory => NonSyncErrorCode::NotDirectory,
        ErrorCode::IsADirectory => NonSyncErrorCode::IsDirectory,
        ErrorCode::InvalidArgument => NonSyncErrorCode::Invalid,
        ErrorCode::BadFileDescriptor => NonSyncErrorCode::BadDescriptor,
        ErrorCode::PermissionDenied => NonSyncErrorCode::Access,
        ErrorCode::AlreadyExists => NonSyncErrorCode::Exist,
        ErrorCode::NotEmpty => NonSyncErrorCode::NotEmpty,
        ErrorCode::NetworkError => NonSyncErrorCode::Io,
        ErrorCode::ProtocolError => NonSyncErrorCode::Io,
        ErrorCode::SerializationError => NonSyncErrorCode::Io,
    };

    TrappableError::from(error_code)
}

impl wasmtime_wasi::bindings::sync::filesystem::types::HostDescriptor for VfsRpcHostState {
    fn read(
        &mut self,
        self_: Resource<wasmtime_wasi::bindings::filesystem::types::Descriptor>,
        len: u64,
        offset: u64,
    ) -> Result<
        (Vec<u8>, bool),
        TrappableError<wasmtime_wasi::bindings::filesystem::types::ErrorCode>,
    > {
        let fd_rep = self_.rep();
        let server_fd = self
            .fd_map
            .get(&fd_rep)
            .ok_or_else(|| TrappableError::trap(anyhow!("File descriptor not found")))?;

        // Seek to offset if needed
        if offset > 0 {
            let seek_req = Request::Seek {
                fd: *server_fd,
                offset: offset as i64,
                whence: 0, // SEEK_SET
            };
            match self
                .rpc_client
                .send_request(&seek_req)
                .map_err(TrappableError::trap)?
            {
                Response::Position { .. } => {}
                Response::Error { code, .. } => {
                    return Err(rpc_error_to_wasi(code));
                }
                _ => return Err(TrappableError::trap(anyhow!("Unexpected response to Seek"))),
            }
        }

        let request = Request::Read {
            fd: *server_fd,
            length: len as usize,
        };

        match self
            .rpc_client
            .send_request(&request)
            .map_err(TrappableError::trap)?
        {
            Response::Data { bytes } => {
                let end_of_stream = bytes.len() < len as usize;
                Ok((bytes, end_of_stream))
            }
            Response::Error { code, .. } => Err(rpc_error_to_wasi(code)),
            _ => Err(TrappableError::trap(anyhow!("Unexpected response to Read"))),
        }
    }

    fn write(
        &mut self,
        self_: Resource<wasmtime_wasi::bindings::filesystem::types::Descriptor>,
        buffer: Vec<u8>,
        offset: u64,
    ) -> Result<u64, TrappableError<wasmtime_wasi::bindings::filesystem::types::ErrorCode>> {
        let fd_rep = self
            .table
            .get::<wasmtime_wasi::bindings::filesystem::types::Descriptor>(&self_)
            .map_err(TrappableError::trap)?
            .rep();
        let server_fd = self
            .fd_map
            .get(&fd_rep)
            .ok_or_else(|| TrappableError::trap(anyhow!("File descriptor not found")))?;

        // Seek to offset if needed
        if offset > 0 {
            let seek_req = Request::Seek {
                fd: *server_fd,
                offset: offset as i64,
                whence: 0, // SEEK_SET
            };
            match self
                .rpc_client
                .send_request(&seek_req)
                .map_err(TrappableError::trap)?
            {
                Response::Position { .. } => {}
                Response::Error { code, .. } => {
                    return Err(TrappableError::from(rpc_error_to_wasi(code)));
                }
                _ => return Err(TrappableError::trap(anyhow!("Unexpected response to Seek"))),
            }
        }

        let request = Request::Write {
            fd: *server_fd,
            data: buffer,
        };

        match self
            .rpc_client
            .send_request(&request)
            .map_err(TrappableError::trap)?
        {
            Response::Written { count } => Ok(count as u64),
            Response::Error { code, .. } => Err(TrappableError::from(rpc_error_to_wasi(code))),
            _ => Err(TrappableError::trap(anyhow!("Unexpected response to Write"))),
        }
    }

    fn drop(
        &mut self,
        rep: Resource<wasmtime_wasi::bindings::filesystem::types::Descriptor>,
    ) -> Result<(), anyhow::Error> {
        let fd_rep = self
            .table
            .get::<wasmtime_wasi::bindings::filesystem::types::Descriptor>(&rep)?
            .rep();
        if let Some(server_fd) = self.fd_map.remove(&fd_rep) {
            let request = Request::Close { fd: server_fd };
            // Ignore response - best effort close
            let _ = self.rpc_client.send_request(&request);
        }
        self.table.delete(rep)?;
        Ok(())
    }

