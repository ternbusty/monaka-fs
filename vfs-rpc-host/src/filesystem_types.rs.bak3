    > {
        let request = Request::Stat { path };

        match self
            .rpc_client
            .send_request(&request)
            .map_err(TrappableError::trap)?
        {
            Response::Metadata { metadata } => Ok(DescriptorStat {
                type_: if metadata.is_dir {
                    DescriptorType::Directory
                } else {
                    DescriptorType::RegularFile
                },
                link_count: 1,
                size: metadata.size,
                data_access_timestamp: Some(
                    wasmtime_wasi::bindings::sync::filesystem::types::Datetime {
                        seconds: metadata.modified,
                        nanoseconds: 0,
                    },
                ),
                data_modification_timestamp: Some(
                    wasmtime_wasi::bindings::sync::filesystem::types::Datetime {
                        seconds: metadata.modified,
                        nanoseconds: 0,
                    },
                ),
                status_change_timestamp: Some(
                    wasmtime_wasi::bindings::sync::filesystem::types::Datetime {
                        seconds: metadata.modified,
                        nanoseconds: 0,
                    },
                ),
            }),
            Response::Error { code, .. } => Err(TrappableError::from(rpc_error_to_wasi(code))),
            _ => Err(TrappableError::trap(anyhow!("Unexpected response to Stat"))),
        }
    }

    fn link_at(
        &mut self,
        _self_: Resource<wasmtime_wasi::bindings::filesystem::types::Descriptor>,
        _old_path_flags: PathFlags,
        _old_path: String,
        _new_descriptor: Resource<wasmtime_wasi::bindings::filesystem::types::Descriptor>,
        _new_path: String,
    ) -> Result<(), TrappableError<wasmtime_wasi::bindings::filesystem::types::ErrorCode>> {
        Err(TrappableError::trap(anyhow!("link_at not supported")))
    }

    fn open_at(
        &mut self,
        _self_: Resource<wasmtime_wasi::bindings::filesystem::types::Descriptor>,
        _path_flags: PathFlags,
        path: String,
        open_flags: OpenFlags,
        flags: DescriptorFlags,
    ) -> Result<
        Resource<wasmtime_wasi::bindings::filesystem::types::Descriptor>,
        TrappableError<wasmtime_wasi::bindings::filesystem::types::ErrorCode>,
    > {
        // Convert WASI open flags to fs-core flags
        let mut fs_flags = 0u32;
        if open_flags.contains(OpenFlags::CREATE) {
            fs_flags |= 0x40; // O_CREAT
        }
        if open_flags.contains(OpenFlags::TRUNCATE) {
            fs_flags |= 0x200; // O_TRUNC
        }
        if flags.contains(DescriptorFlags::WRITE) {
            fs_flags |= 0x02; // O_RDWR
        } else {
            fs_flags |= 0x00; // O_RDONLY
        }

        let request = Request::OpenPath {
            path,
            flags: fs_flags,
        };

        match self
            .rpc_client
            .send_request(&request)
            .map_err(TrappableError::trap)?
        {
            Response::Fd { fd: server_fd } => {
                // Create a local Descriptor resource
                let local_fd_id = self.alloc_fd_id();
                let descriptor = wasmtime_wasi::bindings::filesystem::types::Descriptor::from(local_fd_id);
                let resource = self.table.push(descriptor).map_err(TrappableError::trap)?;

                // Map local ID to server FD
                self.fd_map.insert(local_fd_id, server_fd);

                Ok(resource)
            }
            Response::Error { code, .. } => Err(TrappableError::from(rpc_error_to_wasi(code))),
            _ => Err(TrappableError::trap(anyhow!(
                "Unexpected response to OpenPath"
            ))),
        }
    }

