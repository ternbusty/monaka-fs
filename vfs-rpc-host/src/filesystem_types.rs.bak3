    fn stat(
        &mut self,
        self_: Resource<wasmtime_wasi::bindings::filesystem::types::Descriptor>,
    ) -> Result<
        DescriptorStat,
        TrappableError<wasmtime_wasi::bindings::filesystem::types::ErrorCode>,
    > {
        let fd_rep = self
            .table
            .get::<wasmtime_wasi::bindings::filesystem::types::Descriptor>(&self_)
            .map_err(TrappableError::trap)?
            .rep();
        let server_fd = self
            .fd_map
            .get(&fd_rep)
            .ok_or_else(|| TrappableError::trap(anyhow!("File descriptor not found")))?;

        let request = Request::Fstat { fd: *server_fd };

        match self
            .rpc_client
            .send_request(&request)
            .map_err(TrappableError::trap)?
        {
            Response::Metadata { metadata } => Ok(DescriptorStat {
                type_: if metadata.is_dir {
                    DescriptorType::Directory
                } else {
                    DescriptorType::RegularFile
                },
                link_count: 1,
                size: metadata.size,
                data_access_timestamp: Some(
                    wasmtime_wasi::bindings::sync::filesystem::types::Datetime {
                        seconds: metadata.modified,
                        nanoseconds: 0,
                    },
                ),
                data_modification_timestamp: Some(
                    wasmtime_wasi::bindings::sync::filesystem::types::Datetime {
                        seconds: metadata.modified,
                        nanoseconds: 0,
                    },
                ),
                status_change_timestamp: Some(
                    wasmtime_wasi::bindings::sync::filesystem::types::Datetime {
                        seconds: metadata.modified,
                        nanoseconds: 0,
                    },
                ),
            }),
            Response::Error { code, .. } => Err(TrappableError::from(rpc_error_to_wasi(code))),
            _ => Err(TrappableError::trap(anyhow!("Unexpected response to Fstat"))),
        }
    }

